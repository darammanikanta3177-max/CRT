arr = list(map(int,input("Enter the elements of the array: ").split()))
inc = True
dec = True
for i in range(1,len(arr)):
    if arr[i]>arr[i-1]:
        dec = False
    elif arr[i]<arr[i-1]:
        inc = False
if inc or dec:
    print("The array is monotonic") 
else:
    print("The array is not monotonic")
